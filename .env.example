# DHIS2 Tracker Bulk Import — Environment Configuration
# Copy this file to .env and fill in your values.

# DHIS2 Instance
DHIS2_BASE_URL=http://localhost:8080
DHIS2_API_VERSION=41

# Development proxy (used by `d2-app-scripts start --proxy`)
DHIS2_PROXY_URL=http://localhost:8080

# DHIS2 credentials (dev only — the app uses DHIS2 session auth in production)
DHIS2_USERNAME=admin
DHIS2_PASSWORD=district

# App port
PORT=3000
